{
  "name": "aetherwall",
  "version": "1.0.0",
  "description": "AetherWall — Açık kaynak, ücretsiz canlı duvar kağıdı motoru (Windows)",
  "license": "MIT",
  "author": "AetherWall Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KULLANICI_ADIN/aetherwall.git"
  },
  "bugs": {
    "url": "https://github.com/KULLANICI_ADIN/aetherwall/issues"
  },
  "homepage": "https://github.com/KULLANICI_ADIN/aetherwall#readme",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.aetherwall.app",
    "productName": "AetherWall",
    "copyright": "Copyright © 2026 AetherWall Contributors",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/icon.*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "AetherWall-Setup-${version}.${ext}",
      "sign": null,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AetherWall",
      "license": "assets/license.txt",
      "uninstallDisplayName": "AetherWall ${version}",
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "AetherWall-Portable-${version}.${ext}"
    },
    "publish": null
  },
  "dependencies": {
    "koffi": "^2.8.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}